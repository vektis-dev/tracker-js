{
  "name": "@vektis-io/tracker",
  "version": "1.1.0",
  "description": "Browser JavaScript SDK for sending engagement events to VEKTIS. Zero runtime dependencies, <5KB gzipped.",
  "license": "MIT",
  "author": "VEKTIS",
  "homepage": "https://github.com/vektis-dev/tracker-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vektis-dev/tracker-js.git"
  },
  "bugs": {
    "url": "https://github.com/vektis-dev/tracker-js/issues"
  },
  "type": "module",
  "main": "./dist/vektis-tracker.esm.js",
  "module": "./dist/vektis-tracker.esm.js",
  "browser": "./dist/vektis-tracker.iife.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vektis-tracker.esm.js",
      "browser": "./dist/vektis-tracker.iife.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "tracker": "./bin/tracker.mjs"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup && node scripts/bundle-skills.mjs",
    "bundle:skills": "node scripts/bundle-skills.mjs",
    "smoke": "node scripts/smoke-build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:integration": "TRACKER_INTEGRATION=1 jest --testPathPattern=integration.test",
    "size": "size-limit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@vektis-io/events-schema": "^1.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "size-limit": "^11.1.6",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "zod": "^4.0.0"
  },
  "keywords": [
    "vektis",
    "analytics",
    "tracker",
    "tracking",
    "events",
    "browser",
    "sdk"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
